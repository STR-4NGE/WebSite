NODE_ENV=development
PORT=3000
SESSION_SECRET=change-this-to-a-strong-secret
SHOW_DEBUG_TOKENS=false

# Yerel gelistirme: SQLite icin once "npm install sqlite3" calistirin, sonra:
# DB_CLIENT=sqlite

# PostgreSQL (Render PostgreSQL servisini Web Service'e baglayinca DATABASE_URL otomatik gelir)
DB_CLIENT=postgres
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# veya ayri alanlar:
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=website_blog
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin123!
